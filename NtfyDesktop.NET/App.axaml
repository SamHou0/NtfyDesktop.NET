<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NtfyDesktop.NET.App"
             xmlns:local="using:NtfyDesktop.NET"
             xmlns:themes="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/Ntfy.png"
                      ToolTipText="NtfyDesktop.NET Running..."
                      Clicked="Show_OnClick">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show" Click="Show_OnClick" />
                        <NativeMenuItem Header="Exit" Click="Close_OnClick" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>
    <Application.Styles>
        <themes:MaterialTheme BaseTheme="Dark" PrimaryColor="LightGreen"/>
        <avalonia:MaterialIconStyles />
    </Application.Styles>
</Application>