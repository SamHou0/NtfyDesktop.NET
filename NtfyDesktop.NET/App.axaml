<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NtfyDesktop.NET.App"
             xmlns:local="using:NtfyDesktop.NET"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="NtfyDesktop.NET Running..."
                      Clicked="Show_OnClick">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show" Click="Show_OnClick" />
                        <NativeMenuItem Header="Exit" Click="Close_OnClick" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>
    <Application.Styles>
        <semi:SemiTheme Locale="en-US" />
    </Application.Styles>
</Application>